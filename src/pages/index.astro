  }

  .request-access:hover {
    border-color: #eeece5;
    background: #eeece5;
    color: #030308;
  }

  .request-access:focus-visible {
    outline: 2px solid #eeece5;
    outline-offset: 4px;
  }

  @keyframes aura-shift {
    from {
      background-position: 0% 0%, 100% 100%, 50% 100%, 50% 50%;
      background-size: 112% 112%, 118% 118%, 108% 108%, 100% 100%;
    }

    to {
      background-position: 16% 12%, 83% 86%, 44% 84%, 50% 50%;
      background-size: 128% 128%, 109% 109%, 121% 121%, 100% 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
