    line-height: 0.95;
  }

  .credit {
    max-width: 35rem;
    margin: clamp(1.15rem, 2.4vw, 1.8rem) 0 0;
    color: rgba(238, 236, 229, 0.78);
    font-family: "Instrument Sans", system-ui, sans-serif;
    font-size: clamp(0.8rem, 1.2vw, 0.96rem);
