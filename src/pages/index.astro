<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#030308" />
    <title>Goon Link</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="cover">
      <section class="broadcast" aria-labelledby="site-title">
        <img
          class="mark"
          src="/images/goon-link-mark.png"
          width="1168"
          height="1371"
          alt="Goon Link"
        />
        <h1 id="site-title">GOON LINK</h1>
        <p class="tagline">Starlink for Gooners.</p>
        <p class="credit">
          by the ‘elon musk for gooners’, and the creator of the wank bank app, u/keyraise.
        </p>
        <div class="pricing" aria-label="Lifetime pricing">
          <p class="price price--original"><s>25 USD lifetime.</s></p>
          <p class="price price--offer">temporarily <strong>5 USD Lifetime.</strong></p>
        </div>
        <a class="request-access" href="mailto:invites@twba.mailer.me">Request access</a>
      </section>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    background: #030308;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    width: 100%;
    min-height: 100%;
    margin: 0;
  }

  body {
    overflow-x: hidden;
    overflow-y: auto;
    background: #030308;
  }

  .cover {
    position: relative;
    min-height: 100svh;
    overflow-x: clip;
    background-color: #030308;
    background-image:
      radial-gradient(ellipse 66% 72% at 2% -4%, rgba(24, 57, 154, 0.78) 0%, rgba(10, 23, 68, 0.46) 35%, transparent 73%),
      radial-gradient(ellipse 59% 72% at 104% 77%, rgba(125, 17, 59, 0.54) 0%, rgba(66, 16, 57, 0.22) 39%, transparent 73%),
      radial-gradient(ellipse 60% 54% at 52% 100%, rgba(36, 28, 91, 0.42) 0%, transparent 72%),
      linear-gradient(135deg, #050713 0%, #030308 52%, #09030a 100%);
