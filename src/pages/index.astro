    background-repeat: no-repeat;
    background-size: 112% 112%, 118% 118%, 108% 108%, 100% 100%;
    animation: aura-shift 32s ease-in-out infinite alternate;
  }

  .broadcast {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 100svh;
    margin: 0 auto;
    padding: clamp(2.75rem, 6vw, 6rem) 1.5rem;
