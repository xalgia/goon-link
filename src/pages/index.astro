---
const umamiWebsiteId = "ba6671bd-15b7-437a-895e-e95e6845b731";
const enableUmami = import.meta.env.PROD;
const siteCopy = {
  title: "GOON LINK",
  tagline: "Starlink for Gooners.",
  credit: "built by ‘the elon musk for gooners’, and the creator of the wank bank app, u/keyraise.",
  privacy:
    "No ads, no tracking, no data collection. Secure and E2EE by default, built upon a managed private Nostr relay with NIP-44 encryption and NIP-59 gift-wrapped delivery.",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#030308" />
    <title>Goon Link</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    {enableUmami && (
      <script
        is:inline
        defer
        src="https://stats.thewankbankapp.com/script.js"
        data-website-id={umamiWebsiteId}
        data-domains="goonlink.thewankbankapp.com"
        data-do-not-track="true"
        data-exclude-search="true"
        data-exclude-hash="true"
      ></script>
    )}
  </head>
  <body>
    <main>
      <section class="cover cover--desktop" aria-labelledby="site-title-desktop">
        <section class="broadcast">
          <div class="brand-lockup">
            <img
              class="mark"
              src="/images/goon-link-mark.png"
              width="1168"
              height="1371"
              alt="Goon Link"
            />
            <h1 id="site-title-desktop">{siteCopy.title}</h1>
            <p class="tagline">{siteCopy.tagline}</p>
          </div>
          <div class="offer-stack">
            <p class="credit">{siteCopy.credit}</p>
            <p class="privacy-promise">{siteCopy.privacy}</p>
            <p class="platforms">Android <span aria-hidden="true">·</span> Windows <span aria-hidden="true">·</span> Linux <span aria-hidden="true">·</span> Web</p>
            <div class="pricing" aria-label="Lifetime pricing">
              <p class="price price--original"><s>25 USD lifetime.</s></p>
              <p class="price price--offer">temporarily <strong>5 USD Lifetime.</strong></p>
            </div>
            <a
              class="request-access"
              href="mailto:invites@twba.mailer.me"
              aria-label="Request access by email"
            >
              <span>Request access</span>
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </section>
      </section>

      <section class="cover cover--mobile" aria-labelledby="site-title-mobile">
        <section class="mobile-broadcast">
          <div class="mobile-brand-lockup">
            <img
              class="mobile-mark"
              src="/images/goon-link-mark.png"
              width="1168"
              height="1371"
              alt="Goon Link"
            />
            <h1 class="mobile-title" id="site-title-mobile">{siteCopy.title}</h1>
            <p class="mobile-tagline">{siteCopy.tagline}</p>
          </div>

          <div class="mobile-copy">
            <p class="mobile-credit">{siteCopy.credit}</p>
            <p class="mobile-privacy-promise">{siteCopy.privacy}</p>
            <p class="mobile-platforms">Android <span aria-hidden="true">·</span> Windows <span aria-hidden="true">·</span> Linux <span aria-hidden="true">·</span> Web</p>
          </div>

          <div class="mobile-action">
            <div class="mobile-pricing" aria-label="Lifetime pricing">
              <p class="mobile-price mobile-price--original"><s>25 USD lifetime.</s></p>
              <p class="mobile-price mobile-price--offer"><span>temporarily</span><strong>5 USD Lifetime.</strong></p>
            </div>
            <a
              class="mobile-request-access"
              href="mailto:invites@twba.mailer.me"
              aria-label="Request access by email"
            >
              <span>Request access</span>
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>

<style is:global>
