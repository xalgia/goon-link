    font-family: "Instrument Serif", "Iowan Old Style", Georgia, serif;
    font-size: clamp(1.2rem, 2.25vw, 1.7rem);
    letter-spacing: -0.025em;
    line-height: 0.96;
  }

  .price--original {
    color: rgba(238, 236, 229, 0.46);
  }

  .price--offer {
    border-left: 1px solid rgba(238, 236, 229, 0.25);
    color: #eeece5;
  }

  .price--offer strong {
    margin-left: 0.22em;
    font-weight: 400;
    white-space: nowrap;
  }

  .request-access {
    display: inline-flex;
    min-height: 3.15rem;
    align-items: center;
    justify-content: center;
    margin-top: clamp(1.2rem, 2.4vw, 1.7rem);
