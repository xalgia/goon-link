    align-items: center;
    justify-content: center;
    text-align: center;
    transform: translateZ(0);
  }

  .mark {
    width: clamp(5.65rem, 10.5vw, 9.5rem);
    height: auto;
    margin-bottom: clamp(1.2rem, 2vw, 1.85rem);
    filter: drop-shadow(0 0.7rem 1.5rem rgba(0, 0, 0, 0.42));
  }

  h1 {
    position: relative;
    margin: 0;
    padding: 0 0.08em 0.1em;
    color: #eeece5;
    font-family: "Instrument Serif", "Iowan Old Style", Georgia, serif;
    width: 100%;
    max-width: 100%;
    font-size: clamp(2.5rem, 12.7vw, 12.8rem);
    font-weight: 400;
    letter-spacing: -0.07em;
    line-height: 0.78;
    white-space: nowrap;
    text-align: center;
    text-shadow: 0 0.04em 0.24em rgba(0, 0, 0, 0.38);
  }

  .tagline {
    max-width: 30rem;
    margin: clamp(1.2rem, 2.5vw, 2rem) 0 0;
